<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">

    <Grid Background="#ECF0F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Left column (cart) flexible; right column fixed for payment panel but collapses on narrow widths -->
            <ColumnDefinition Width="*" MinWidth="300" />
            <ColumnDefinition Width="380" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <!-- Back button (top-left) -->
        <Button Grid.Row="0" Command="{Binding Voltar}"
                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12"
                Panel.ZIndex="200"
                Style="{StaticResource MaterialDesignRaisedLightButton}"
                Background="#6A1B9A"
                Foreground="White"
                Padding="10"
                materialDesign:ButtonAssist.CornerRadius="12">
            <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>

        <!-- Cart items area with its own scroll (fixed height) -->
        <Border Grid.Row="1" Grid.Column="0" Margin="12,8,8,8" Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Itens no Carrinho" FontSize="18" FontWeight="Bold" Margin="6" />

                <!-- Scroll only the items list; payment panel not affected -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Pedido.Produtos}" MinWidth="300">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="4" Background="White" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Height="78" Width="78" HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding Produto.Imagem}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Produto.Descricao}" FontWeight="SemiBold" FontSize="16" TextWrapping="Wrap" MaxHeight="48"/>
                                            <TextBlock Text="{Binding Produto.Referencia}" FontSize="12" Foreground="#666" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="Qtd: " FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Quantidade}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="R$" FontWeight="ExtraBold" FontSize="16" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N2}}" FontWeight="ExtraBold" FontSize="18" HorizontalAlignment="Right" />
                                        </StackPanel>

                                        <!-- Remove button positioned top-right of item -->
                                        <Button Width="28" Height="28" Background="#D32F2F" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoverItem, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Padding="0" Margin="-8,-8,0,0">
                                            <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Payment panel fixed in right column; stays visible regardless of items scroll -->
        <Border Grid.Row="1" Grid.Column="1" Margin="8,40,12,40" Background="White" CornerRadius="8" Padding="12" Panel.ZIndex="150">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                <TextBlock Text="Faça seu pagamento" FontSize="20" FontWeight="Bold" Margin="0,0,0,8" />

                <ComboBox FontSize="16" FontWeight="SemiBold" SelectedIndex="0" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <ComboBoxItem Content="Selecionar um Cartão"/>
                    <ComboBoxItem Content="Crédito"/>
                    <ComboBoxItem Content="Débito"/>
                </ComboBox>

                <TextBlock Text="Número do Cartão" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <TextBox Text="{Binding NumeroCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="14" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nome no Cartão" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <TextBox Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="14" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="CVV" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <TextBox Text="{Binding CVV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="14" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Data de Validade" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <DatePicker SelectedDate="{Binding DataValidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="14" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Pagar" Command="{Binding Receber}" Width="120" Height="36" Background="#008000" Foreground="White" materialDesign:ButtonAssist.CornerRadius="8"/>
                </StackPanel>

                <!-- Subtotal display pinned to bottom of payment panel -->
                <Border BorderThickness="1" BorderBrush="#EEE" Margin="0,12,0,0" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Subtotal: " FontSize="16" FontWeight="SemiBold" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Pedido.Total, StringFormat={}{0:N2}}" FontSize="16" FontWeight="ExtraBold" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
