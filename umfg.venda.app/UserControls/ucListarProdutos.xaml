<UserControl x:Class="umfg.venda.app.UserControls.ucListarProdutos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080">
    <Viewbox Stretch="Uniform">
        <Grid Background="#ECF0F1" Width="1080" Height="720">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Back button (top-left) -->
            <Button Command="{Binding Voltar}"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
                    Panel.ZIndex="100"
                    Style="{StaticResource MaterialDesignRaisedLightButton}"
                    Background="#6A1B9A"
                    Foreground="White"
                    Padding="6"
                    materialDesign:ButtonAssist.CornerRadius="12">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18" />
            </Button>

            <!-- Product list -->
            <Grid Grid.Row="0">
                <ScrollViewer Margin="10">
                    <ListBox ItemsSource="{Binding Produtos}"
                             SelectedItem="{Binding ProdutoSelecionado}"
                             SelectionMode="Single"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="300" Height="380">
                                    <StackPanel>
                                        <Border Width="170" Height="170"
                                                CornerRadius="5" Margin="5">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="1"/>
                                            </Border.Effect>

                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Imagem}"/>
                                            </Border.Background>
                                        </Border>

                                        <TextBlock Margin="5"
                                                   Text="{Binding Referencia}"
                                                   FontSize="17"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>

                                        <TextBlock Margin="5"
                                                   Text="{Binding Descricao}"
                                                   TextWrapping="Wrap"
                                                   FontSize="25"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Margin="5 0" Text="R$" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Valor}" FontSize="17" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </ScrollViewer>
            </Grid>

            <!-- Bottom bar with actions and subtotal -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <Button
                        CommandParameter="{Binding}"
                        Command="{Binding Adicionar, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesignRaisedLightButton}"
                        Margin="0 0 8 0"
                        Foreground="White"
                        Width="120"
                        Height="36"
                        materialDesign:ButtonAssist.CornerRadius="18">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Cart" Width="18" Height="18" Foreground="White"/>
                            <Border Background="#FFFFFF" CornerRadius="10" Margin="8,0,0,0" Padding="6,0">
                                <TextBlock Text="+" Foreground="#6A1B9A" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button
                        CommandParameter="{Binding}"
                        Command="{Binding Remover, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesignRaisedLightButton}"
                        Foreground="White"
                        Width="120"
                        Height="36"
                        materialDesign:ButtonAssist.CornerRadius="18">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Cart" Width="18" Height="18" Foreground="White"/>
                            <Border Background="#FFFFFF" CornerRadius="10" Margin="8,0,0,0" Padding="6,0">
                                <TextBlock Text="-" Foreground="#6A1B9A" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Subtotal: " Margin="0 0 8 0" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="R$ " FontWeight="SemiBold" Margin="0 0 8 0" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Pedido.Total}" FontWeight="SemiBold" Margin="0 0 12 0" FontSize="16" VerticalAlignment="Center"/>

                    <Button
                        Content="_Pagar"
                        CommandParameter="{Binding}"
                        Command="{Binding Receber, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesignRaisedLightButton}"
                        Background="#8BC34A"
                        Foreground="White"
                        Width="110"
                        Height="36"
                        materialDesign:ButtonAssist.CornerRadius="18"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>