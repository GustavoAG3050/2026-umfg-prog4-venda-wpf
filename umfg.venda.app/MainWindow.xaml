<Window x:Class="umfg.venda.app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:umfg.venda.app"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"        
        WindowState="Maximized" Height="720" Width="1080">
    <Grid Background="#ECF0F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="25,0,0,8" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding Titulo}" FontSize="28" FontWeight="SemiBold"
                       FontFamily="Trebuchet MS" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Content="Iniciar"
                CommandParameter="{Binding}"
                Command="{Binding ListarProdutos, UpdateSourceTrigger=PropertyChanged}"
                Margin="0"
                Background="White"
                BorderBrush="#E6E6E6"
                BorderThickness="1"
                Padding="20,8"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="#333333"
                materialDesign:ButtonAssist.CornerRadius="24"
                MinWidth="120"
                Width="Auto"
                Height="48">
            <Button.Effect>
                <DropShadowEffect Color="#66000000" BlurRadius="12" ShadowDepth="2" Opacity="0.18" />
            </Button.Effect>
        </Button>
        
        <Frame Grid.Row="0" 
               Content="{Binding UserControl}"
               NavigationUIVisibility="Hidden">
        </Frame>
    </Grid>
</Window>