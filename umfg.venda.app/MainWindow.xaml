<Window x:Class="umfg.venda.app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:umfg.venda.app"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"        
        WindowState="Maximized" Height="720" Width="1080">
    <Grid Background="#ECF0F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Title moved to bottom left -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="25,0,0,8" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding Titulo}" FontSize="28" FontWeight="SemiBold"
                       FontFamily="Trebuchet MS" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Content="_Iniciar"
                FontSize="24"
                FontWeight="SemiBold"
                CommandParameter="{Binding}"
                Command="{Binding ListarProdutos, UpdateSourceTrigger=PropertyChanged}"                        
                Style="{StaticResource MaterialDesignRaisedLightButton}"
                Margin="0"
                Foreground="White"
                materialDesign:ButtonAssist.CornerRadius="18"
                Width="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource MulConverter}, ConverterParameter=0.2}"
                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource MulConverter}, ConverterParameter=0.2}"/>
        
        <Frame Grid.Row="0" 
               Content="{Binding UserControl}"
               NavigationUIVisibility="Hidden">
        </Frame>
    </Grid>
</Window>